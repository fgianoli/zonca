# ── Database ──────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=zonca
POSTGRES_USER=zonca
POSTGRES_PASSWORD=changeme

# ── Backend ───────────────────────────────────────
SECRET_KEY=changeme-generate-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── SMTP (OVH) - fallback se non configurato da interfaccia admin ──
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_USER=noreply@tuodominio.it
SMTP_PASSWORD=changeme
SMTP_FROM=Remiera Zonca <noreply@tuodominio.it>

# ── Promemoria certificati medici ─────────────────
# (Configurabili anche da interfaccia admin in Impostazioni > SMTP)
# REMINDER_DAYS_BEFORE=30

# ── Ports (Docker) ────────────────────────────────
DB_PORT=5432
API_PORT=8000
WEB_PORT=80

# ── Frontend ──────────────────────────────────────
VITE_API_URL=http://localhost:8000/api
