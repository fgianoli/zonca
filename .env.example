# ── Database ──────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=zonca
POSTGRES_USER=zonca
POSTGRES_PASSWORD=changeme

# ── Backend ───────────────────────────────────────
SECRET_KEY=changeme-generate-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Domini abilitati al CORS (separati da virgola). Se vuoto usa i default
# che includono vogavenetazonca.it + localhost per dev.
# CORS_ORIGINS=https://vogavenetazonca.it,https://www.vogavenetazonca.it

# URL pubblico base dell'app (usato per link nelle email e feed iCal)
PUBLIC_BASE_URL=https://vogavenetazonca.it

# ── SMTP - fallback se non configurato da interfaccia admin ──
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Ports (Docker, solo per dev locale) ───────────
DB_PORT=5432
API_PORT=8000
WEB_PORT=8080
